{
  "languages": {
    "TypeScript": {
      "language_servers": ["tsgo", "!vtsls", "!typescript-language-server", "!eslint", "..."],
      "formatter": [
        { "code_action": "source.fixAll.oxc" },
        {
          "external": {
            "command": "./node_modules/.bin/oxfmt",
            "arguments": ["--stdin-filepath", "{buffer_path}"]
          }
        }
      ],
      "format_on_save": "on"
    },
    "TSX": {
      "language_servers": ["tsgo", "!vtsls", "!typescript-language-server", "!eslint", "..."],
      "formatter": [
        { "code_action": "source.fixAll.oxc" },
