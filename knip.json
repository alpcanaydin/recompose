{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    "apps/desktop": {
      "ignoreDependencies": ["fast-check"],
      "ignore": ["src/renderer/src/app/routeTree.gen.ts"]
    },
    "packages/contracts": {
      "entry": ["src/**/*.test-d.ts"],
      "ignoreDependencies": ["fast-check"]
    },
    ".": {
      "entry": ["steiger.config.ts"],
      "ignoreDependencies": ["@steiger/toolkit", "@swc/core"]
    }
  }
}
