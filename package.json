{
  "name": "recompose",
  "version": "1.0.0",
  "private": true,
  "description": "",
  "keywords": [],
  "license": "MIT",
  "author": "Alpcan Aydin <alpcan@alpcanaydin.com>",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "lint:root": "oxlint",
    "lint:fix": "oxlint --fix",
    "lint:boundaries": "depcruise apps packages",
    "lint:dead": "knip",
    "lint:dup": "jscpd -c .jscpd.json apps packages",
    "lint:prose": "mise exec -- vale --glob=\"!{node_modules,.agents,.claude/skills,.claude/worktrees,.vale,out,dist,coverage}/**\" .",
    "lint:fsd": "steiger apps/desktop/src/renderer/src --fail-on-warnings",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "devDependencies": {
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "@feature-sliced/steiger-plugin": "0.7.0",
    "@steiger/toolkit": "0.2.3",
    "@stylistic/eslint-plugin": "5.10.0",
    "@swc/core": "1.15.46",
    "dependency-cruiser": "18.1.0",
    "jscpd": "5.0.12",
    "knip": "6.29.0",
    "lefthook": "2.1.10",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "oxlint-plugin-react-doctor": "0.8.3",
    "oxlint-tsgolint": "0.25.0",
    "steiger": "0.6.0",
    "turbo": "2.10.5",
    "vitest": "4.1.10"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.15.1",
      "onFail": "download"
    }
  },
  "packageManager": "pnpm@11.15.1"
}
