{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build", "typecheck"],
      "inputs": ["$TURBO_DEFAULT$", "$TURBO_ROOT$/tsconfig.strict.json"],
      "outputs": ["dist/**", "out/**"]
    },
    "typecheck": {
      "inputs": ["$TURBO_DEFAULT$", "$TURBO_ROOT$/tsconfig.strict.json"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "inputs": ["$TURBO_DEFAULT$", "$TURBO_ROOT$/.oxlintrc.json"]
    },
    "test": {}
  }
}
