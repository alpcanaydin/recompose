{
  "extends": ["@electron-toolkit/tsconfig/tsconfig.web.json", "../../tsconfig.strict.json"],
  "include": [
    "src/renderer/src/env.d.ts",
    "src/renderer/src/**/*",
    "src/renderer/src/**/*.tsx",
    "src/preload/*.d.ts",
    ".storybook/preview.ts",
    ".storybook/recompose-bridge.tsx"
  ],
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "types": ["@vitest/browser-playwright"],
    "paths": {
      "@renderer/*": ["./src/renderer/src/*"]
    }
  }
}
