{
  "name": "@recompose/desktop",
  "version": "0.1.0",
  "description": "recompose desktop shell",
  "license": "MIT",
  "author": "Alpcan Aydin <alpcan@alpcanaydin.com>",
  "main": "./out/main/index.js",
  "scripts": {
    "lint": "oxlint",
    "test": "vitest run --coverage",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "pnpm run typecheck:node && pnpm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "pnpm run typecheck && pnpm run build && electron-builder --dir",
    "build:win": "pnpm run typecheck && pnpm run build && electron-builder --win",
    "build:mac": "pnpm run typecheck && pnpm run build && electron-builder --mac",
    "build:linux": "pnpm run typecheck && pnpm run build && electron-builder --linux"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "@tanstack/react-router": "1.170.18",
    "electron-liquid-glass": "^1.1.1"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "2.0.0",
    "@electron/fuses": "2.1.3",
    "@fast-check/vitest": "0.4.1",
    "@recompose/contracts": "workspace:*",
    "@tailwindcss/vite": "4.3.3",
    "@tanstack/react-query": "5.101.4",
    "@tanstack/react-query-devtools": "5.101.4",
    "@tanstack/react-router-devtools": "1.167.0",
    "@tanstack/router-plugin": "1.168.23",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/browser-playwright": "4.1.10",
    "@vitest/coverage-v8": "4.1.10",
    "electron": "43.1.1",
    "electron-builder": "26.15.3",
    "electron-vite": "6.0.0-beta.1",
    "fast-check": "4.9.0",
    "oxlint": "1.74.0",
    "oxlint-tsgolint": "7.0.2001",
    "playwright": "1.61.1",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "tailwindcss": "4.3.3",
    "typescript": "7.0.2",
    "vite": "8.1.5",
    "vitest": "4.1.10",
    "vitest-browser-react": "2.2.0"
  }
}
